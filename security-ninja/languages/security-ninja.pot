msgstr ""

#: modules/auto-fixer/class-wf-sn-fixes.php:719
msgid "Disable XMLRPC Pingback"
msgstr ""

#: modules/auto-fixer/class-wf-sn-fixes.php:720
msgid "Prevents WordPress from participating in and being a victim of pingback denial of service attacks by removing the pingback.ping method and X-Pingback header."
msgstr ""

#: modules/auto-fixer/class-wf-sn-fixes.php:740
msgid "Disable Username Enumeration"
msgstr ""

#: modules/auto-fixer/class-wf-sn-fixes.php:741
msgid "Prevents username discovery via ?author=N scans, REST API /wp-json/wp/v2/users endpoint, and oEmbed API"
msgstr ""

#: modules/auto-fixer/class-wf-sn-fixes.php:761
msgid "Remove unwanted files"
msgstr ""

#: modules/auto-fixer/class-wf-sn-fixes.php:762
msgid "If enabled, a daily cleanup process cleans up unneeded files from your WordPress installation. Access to .bak, .sql and other files are blocked via the firewall module."
